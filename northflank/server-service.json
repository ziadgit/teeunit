{
  "$schema": "https://api.northflank.com/v1/schemas/deployment",
  "name": "TeeUnit Server",
  "description": "TeeUnit environment server for remote RL training",
  "spec": {
    "type": "service",
    "build": {
      "dockerfile": "Dockerfile",
      "context": "."
    },
    "resources": {
      "cpu": {
        "cores": 2
      },
      "memory": {
        "megabytes": 4096
      }
    },
    "runtime": {
      "environment": {
        "PORT": "7860",
        "TEEWORLDS_PORT": "8303",
        "PYTHONUNBUFFERED": "1"
      }
    },
    "ports": [
      {
        "name": "http",
        "internalPort": 7860,
        "public": true,
        "protocol": "HTTP"
      }
    ],
    "healthCheck": {
      "enabled": true,
      "path": "/health",
      "port": 7860,
      "protocol": "HTTP",
      "initialDelaySeconds": 15,
      "periodSeconds": 30,
      "timeoutSeconds": 10,
      "successThreshold": 1,
      "failureThreshold": 3
    },
    "scaling": {
      "minReplicas": 1,
      "maxReplicas": 1
    }
  }
}
