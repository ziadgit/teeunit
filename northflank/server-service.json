{
  "name": "TeeUnit Environment",
  "description": "TeeUnit environment server for RL training",
  "billing": {
    "deploymentPlan": "nf-gpu-hack-4-16"
  },
  "vcsData": {
    "projectUrl": "https://github.com/ziadgit/teeunit",
    "projectType": "github",
    "projectBranch": "main"
  },
  "buildSettings": {
    "dockerfile": {
      "buildEngine": "kaniko",
      "dockerFilePath": "/Dockerfile",
      "dockerWorkDir": "/"
    }
  },
  "deployment": {
    "instances": 1,
    "storage": {
      "ephemeralStorage": {
        "storageSize": 10240
      }
    },
    "docker": {
      "configType": "default"
    }
  },
  "runtimeEnvironment": {
    "PORT": "7860",
    "TEEWORLDS_PORT": "8303",
    "PYTHONUNBUFFERED": "1"
  },
  "ports": [
    {
      "name": "http",
      "internalPort": 7860,
      "protocol": "HTTP",
      "public": false
    }
  ],
  "healthChecks": [
    {
      "type": "livenessProbe",
      "protocol": "HTTP",
      "port": 7860,
      "path": "/health",
      "initialDelaySeconds": 30,
      "periodSeconds": 30,
      "timeoutSeconds": 10,
      "failureThreshold": 3
    }
  ]
}
