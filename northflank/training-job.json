{
  "name": "TeeUnit GPU Training",
  "description": "Self-play RL training for TeeUnit multi-agent arena",
  "billing": {
    "deploymentPlan": "nf-gpu-hack-16-192-gpu"
  },
  "vcsData": {
    "projectUrl": "https://github.com/ziadgit/teeunit",
    "projectType": "github",
    "projectBranch": "main",
    "dockerFilePath": "/Dockerfile.gpu",
    "dockerWorkDir": "/"
  },
  "buildSettings": {
    "dockerfile": {
      "buildEngine": "kaniko",
      "dockerFilePath": "/Dockerfile.gpu",
      "dockerWorkDir": "/"
    }
  },
  "deployment": {
    "storage": {
      "ephemeralStorage": {
        "storageSize": 51200
      }
    },
    "docker": {
      "configType": "customCommand",
      "customCommand": "python -m teeunit.train train --steps 500000 --device cuda --save-path /app/models --single-agent --upload-hf --hf-repo ziadbc/teeunit-agent"
    },
    "gpu": {
      "enabled": true,
      "configuration": {
        "gpuType": "h100-80",
        "gpuCount": 1
      }
    }
  },
  "runtimeEnvironment": {
    "CUDA_VISIBLE_DEVICES": "0",
    "PYTHONUNBUFFERED": "1"
  },
  "runtimeSecrets": [
    {
      "id": "hf-token",
      "secretType": "environment"
    }
  ],
  "backoffLimit": 0
}
